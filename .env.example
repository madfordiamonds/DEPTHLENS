# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: The API Web Key of your configured Firebase project.
# To find it, go to your Firebase Console -> Project Settings -> General -> Web API Key.
FIREBASE_API_KEY=PLACEHOLDER_FIREBASE_API_KEY

# FIREBASE_PROJECT_ID: Your unique Firebase Project ID.
# Found in Firebase Console -> Project Settings -> General -> Project ID.
FIREBASE_PROJECT_ID=PLACEHOLDER_FIREBASE_PROJECT_ID

# FIREBASE_APP_ID: Your unique Firebase Mobile App ID.
# Found in Firebase Console -> Project Settings -> General -> Your Apps (Android).
FIREBASE_APP_ID=PLACEHOLDER_FIREBASE_APP_ID
